@page
@model KeepBill.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
    var googleLoginUri = Url.Action("GoogleOneTap", "Auth", null, Request.Scheme);
}

<div class="auth-form-shell">
    <div class="auth-heading text-center mb-4">
        <p class="auth-kicker mb-1">Bem-vindo de volta</p>
        <h2 class="h4 mb-2">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Acede ao teu painel de faturacao em segundos.</p>
    </div>

    <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">Email</label>
            <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" placeholder="nome@empresa.com" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Password</label>
            <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="current-password" placeholder="A tua password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-check mb-4">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label">Manter sessao iniciada</label>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">Entrar</button>
    </form>

    @if (Model.HasGoogleIdentity && !string.IsNullOrWhiteSpace(googleLoginUri))
    {
        <div class="auth-divider my-3"><span>ou</span></div>
        <script src="https://accounts.google.com/gsi/client" async defer></script>
        <div id="g_id_onload"
             data-client_id="@Model.GoogleClientId"
             data-context="signin"
             data-ux_mode="redirect"
             data-login_uri="@googleLoginUri"
             data-itp_support="true">
        </div>
        <div class="auth-social-section mb-2">
            <div class="g_id_signin"
                 data-type="standard"
                 data-shape="pill"
                 data-theme="outline"
                 data-text="signin_with"
                 data-size="large"
                 data-logo_alignment="left">
            </div>
        </div>
    }
    else if (Model.ExternalLogins != null && Model.ExternalLogins.Count > 0)
    {
        <div class="auth-divider my-3"><span>ou</span></div>
        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            @foreach (var provider in Model.ExternalLogins)
            {
                <button type="submit" class="btn btn-outline-secondary w-100 py-2 mb-2" name="provider" value="@provider.Name" title="Entrar com @provider.DisplayName">
                    Entrar com @provider.DisplayName
                </button>
            }
        </form>
    }
</div>

<div class="auth-links mt-4 text-center">
    <a class="small" asp-page="./ForgotPassword">Esqueceste a password?</a>
    <p class="mt-3 mb-0">Ainda nao tens conta? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Regista-te</a></p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
