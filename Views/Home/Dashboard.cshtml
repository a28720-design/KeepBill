@model KeepBill.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-12">
        <section class="kb-dash-hero">
            <div>
                <p class="kb-dash-hero-kicker mb-2">Painel de controlo</p>
                <h2 class="kb-dash-hero-title mb-2">Situacao financeira em tempo real</h2>
                <p class="mb-0 text-muted">Acompanha rapidamente o que entrou, o que falta receber e o que exige acao imediata.</p>
            </div>
            <div class="kb-dash-hero-actions">
                <a asp-controller="Invoices" asp-action="Create" class="btn btn-primary">Criar fatura</a>
                <a asp-controller="Payments" asp-action="Create" class="btn btn-outline-primary">Registar pagamento</a>
            </div>
        </section>
    </div>

    <div class="col-md-3 col-6">
        <article class="kb-stat-card">
            <p>Clientes</p>
            <h3>@Model.TotalCustomers</h3>
        </article>
    </div>
    <div class="col-md-3 col-6">
        <article class="kb-stat-card">
            <p>Faturas emitidas</p>
            <h3>@Model.InvoicesIssued</h3>
        </article>
    </div>
    <div class="col-md-3 col-6">
        <article class="kb-stat-card is-alert">
            <p>Em atraso</p>
            <h3>@Model.OverdueInvoices</h3>
        </article>
    </div>
    <div class="col-md-3 col-6">
        <article class="kb-stat-card is-alert">
            <p>Valor em atraso</p>
            <h3>@Model.OverdueAmount.ToString("C")</h3>
        </article>
    </div>
    <div class="col-md-6">
        <article class="kb-stat-card">
            <p>Recebido este mes</p>
            <h3>@Model.PaidThisMonth.ToString("C")</h3>
        </article>
    </div>
    <div class="col-md-6">
        <article class="kb-stat-card">
            <p>Montante por receber</p>
            <h3>@Model.OutstandingAmount.ToString("C")</h3>
        </article>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <section class="kb-panel h-100">
            <header class="kb-panel-head">
                <h5 class="mb-0">Faturas proximas do vencimento</h5>
                <a asp-controller="Invoices" asp-action="Index" class="btn btn-sm btn-outline-secondary">Ver todas</a>
            </header>
            <div class="kb-panel-body p-0">
                @if (!Model.UpcomingInvoices.Any())
                {
                    <div class="p-4 text-muted">Sem faturas pendentes nos proximos dias.</div>
                }
                else
                {
                    <div class="table-responsive kb-table-wrap">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Numero</th>
                                    <th>Cliente</th>
                                    <th>Vencimento</th>
                                    <th>Saldo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var invoice in Model.UpcomingInvoices)
                            {
                                <tr>
                                    <td>@invoice.Number</td>
                                    <td>@invoice.CustomerName</td>
                                    <td>@invoice.DueDate.ToString("dd/MM")</td>
                                    <td>@invoice.Balance.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-primary">Abrir</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    </div>
    <div class="col-lg-5">
        <section class="kb-panel h-100">
            <header class="kb-panel-head">
                <h5 class="mb-0">Resumo mensal</h5>
            </header>
            <div class="kb-panel-body">
                @if (!Model.MonthlySummary.Any())
                {
                    <p class="text-muted mb-0">Ainda nao existem faturas emitidas neste mes.</p>
                }
                else
                {
                    <div class="kb-status-list">
                        @foreach (var item in Model.MonthlySummary)
                        {
                            <div class="kb-status-item">
                                <div>
                                    <strong>@item.Status</strong>
                                    <p class="mb-0">@item.Count faturas</p>
                                </div>
                                <span>@item.Total.ToString("C")</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12">
        <section class="kb-panel">
            <header class="kb-panel-head">
                <h5 class="mb-0">Faturas em atraso</h5>
                <a asp-controller="Invoices" asp-action="Index" asp-route-overdueOnly="true" class="btn btn-sm btn-outline-danger">Ver vencidas</a>
            </header>
            <div class="kb-panel-body p-0">
                @if (!Model.OverdueInvoiceCards.Any())
                {
                    <div class="p-4 text-muted">Sem faturas em atraso.</div>
                }
                else
                {
                    <div class="table-responsive kb-table-wrap">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Numero</th>
                                    <th>Cliente</th>
                                    <th>Vencimento</th>
                                    <th>Saldo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var invoice in Model.OverdueInvoiceCards)
                            {
                                <tr>
                                    <td>@invoice.Number</td>
                                    <td>@invoice.CustomerName</td>
                                    <td><span class="text-danger">@invoice.DueDate.ToString("dd/MM/yyyy")</span></td>
                                    <td>@invoice.Balance.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-secondary">Abrir</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

