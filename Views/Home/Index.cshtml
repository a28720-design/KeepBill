@model KeepBill.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card metric-card shadow-sm">
            <div class="card-body">
                <p class="text-muted mb-1">Clientes</p>
                <h2 class="mb-0">@Model.TotalCustomers</h2>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card metric-card shadow-sm">
            <div class="card-body">
                <p class="text-muted mb-1">Produtos ativos</p>
                <h2 class="mb-0">@Model.ActiveProducts</h2>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card metric-card shadow-sm">
            <div class="card-body">
                <p class="text-muted mb-1">Faturas emitidas</p>
                <h2 class="mb-0">@Model.InvoicesIssued</h2>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card metric-card shadow-sm border-danger-subtle">
            <div class="card-body">
                <p class="text-muted mb-1">Em atraso</p>
                <h2 class="mb-0 text-danger">@Model.OverdueInvoices</h2>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card metric-card shadow-sm border-danger-subtle">
            <div class="card-body">
                <p class="text-muted mb-1">Valor em atraso</p>
                <h2 class="mb-0 text-danger">@Model.OverdueAmount.ToString("C")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card metric-card shadow-sm">
            <div class="card-body">
                <p class="text-muted mb-1">Recebido este mês</p>
                <h2 class="mb-0">@Model.PaidThisMonth.ToString("C")</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Faturas próximas do vencimento</h5>
                    <a asp-controller="Invoices" asp-action="Index" class="btn btn-sm btn-outline-secondary">Ver todas</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (!Model.UpcomingInvoices.Any())
                {
                    <div class="p-4 text-muted">Sem faturas pendentes nos próximos dias.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Número</th>
                                    <th>Cliente</th>
                                    <th>Vencimento</th>
                                    <th>Saldo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var invoice in Model.UpcomingInvoices)
                            {
                                <tr>
                                    <td>@invoice.Number</td>
                                    <td>@invoice.CustomerName</td>
                                    <td>@invoice.DueDate.ToString("dd/MM")</td>
                                    <td>@invoice.Balance.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-primary">Detalhes</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0">Montante por receber</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <p class="text-muted">Saldo corrente</p>
                <h1>@Model.OutstandingAmount.ToString("C")</h1>
                <small class="text-muted">Soma das faturas em aberto (exclui pagas/canceladas)</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Faturas em atraso</h5>
                <a asp-controller="Invoices" asp-action="Index" asp-route-overdueOnly="true" class="btn btn-sm btn-outline-danger">Ver vencidas</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.OverdueInvoiceCards.Any())
                {
                    <div class="p-4 text-muted">Sem faturas em atraso.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Numero</th>
                                    <th>Cliente</th>
                                    <th>Vencimento</th>
                                    <th>Saldo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var invoice in Model.OverdueInvoiceCards)
                            {
                                <tr>
                                    <td>@invoice.Number</td>
                                    <td>@invoice.CustomerName</td>
                                    <td><span class="text-danger">@invoice.DueDate.ToString("dd/MM/yyyy")</span></td>
                                    <td>@invoice.Balance.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-secondary">Abrir</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Resumo mensal (@DateTime.UtcNow)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Estado</th>
                                <th>Quantidade</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.MonthlySummary.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">Ainda não existem faturas emitidas neste mês.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.MonthlySummary)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td>@item.Count</td>
                                    <td>@item.Total.ToString("C")</td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
