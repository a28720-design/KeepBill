@model KeepBill.Models.Invoice
@{
    ViewData["Title"] = $"Fatura {Model.Number}";
    var paidAmount = ViewData["PaidAmount"] is decimal p ? p : 0m;
    var balance = ViewData["BalanceAmount"] is decimal b ? b : Model.GrandTotal;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">@Model.Customer?.Name</p>
    </div>
    <div class="btn-group">
        <a asp-action="ExportPdf" asp-route-id="@Model.Id" class="btn btn-outline-secondary">PDF</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Lista</a>
    </div>
</div>

<form asp-action="UpdateStatus" method="post" class="card shadow-sm mb-3">
    @Html.AntiForgeryToken()
    <div class="card-body d-flex flex-wrap align-items-center gap-2">
        <input type="hidden" name="id" value="@Model.Id" />
        <span class="text-muted">Estado atual:</span>
        <span class="badge @GetStatusClass(Model.Status)">@Model.Status</span>
        <select class="form-select form-select-sm" name="status" style="max-width: 220px;">
            @foreach (var status in Enum.GetValues<KeepBill.Models.InvoiceStatus>())
            {
                <option value="@status" selected="@(Model.Status == status ? "selected" : null)">@status</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-outline-primary">Atualizar estado</button>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted">Estado</div>
                <div class="h4 mt-1">
                    <span class="badge @GetStatusClass(Model.Status)">@Model.Status</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted">Emitida em</div>
                <div class="h5 mt-1">@Model.IssueDate.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted">Vencimento</div>
                <div class="h5 mt-1">@Model.DueDate.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted">Pago</div>
                <div class="h5 mt-1">@paidAmount.ToString("C")</div>
                <div class="text-muted small">Em falta: @balance.ToString("C")</div>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive shadow-sm bg-white mb-4">
    <table class="table mb-0">
        <thead class="table-light">
            <tr>
                <th>Descricao</th>
                <th class="text-end">Qtd.</th>
                <th class="text-end">Preco</th>
                <th class="text-end">IVA %</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var line in Model.Lines)
        {
            <tr>
                <td>@line.Description</td>
                <td class="text-end">@line.Quantity</td>
                <td class="text-end">@line.UnitPrice.ToString("C")</td>
                <td class="text-end">@line.VatRate</td>
                <td class="text-end">@line.LineTotal.ToString("C")</td>
            </tr>
        }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="4" class="text-end">Subtotal</th>
                <th class="text-end">@Model.Subtotal.ToString("C")</th>
            </tr>
            <tr>
                <th colspan="4" class="text-end">IVA</th>
                <th class="text-end">@Model.VatTotal.ToString("C")</th>
            </tr>
            <tr>
                <th colspan="4" class="text-end">Total</th>
                <th class="text-end">@Model.GrandTotal.ToString("C")</th>
            </tr>
        </tfoot>
    </table>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5>Notas</h5>
        <p>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-4 mb-2">
    <h5 class="mb-0">Pagamentos</h5>
    <a asp-controller="Payments" asp-action="Create" asp-route-invoiceId="@Model.Id" class="btn btn-outline-success btn-sm">Registar pagamento</a>
</div>

@if (Model.Payments.Any())
{
    <div class="table-responsive shadow-sm bg-white">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr>
                    <th>Data</th>
                    <th>Metodo</th>
                    <th>Referencia</th>
                    <th>Notas</th>
                    <th class="text-end">Valor</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var payment in Model.Payments.OrderByDescending(p => p.PaidAt))
            {
                <tr>
                    <td>@payment.PaidAt.ToString("dd/MM/yyyy")</td>
                    <td>@payment.Method</td>
                    <td>@payment.Reference</td>
                    <td>@payment.Notes</td>
                    <td class="text-end">@payment.Amount.ToString("C")</td>
                    <td class="text-end">
                        <a asp-controller="Payments" asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">Ainda nao existem pagamentos registados para esta fatura.</div>
}

@functions {
    private string GetStatusClass(KeepBill.Models.InvoiceStatus status)
    {
        return status switch
        {
            KeepBill.Models.InvoiceStatus.Paid => "bg-success",
            KeepBill.Models.InvoiceStatus.PartiallyPaid => "bg-info",
            KeepBill.Models.InvoiceStatus.Cancelled => "bg-secondary",
            KeepBill.Models.InvoiceStatus.Issued => "bg-primary",
            _ => "bg-warning text-dark"
        };
    }
}
