@model KeepBill.Models.ViewModels.InvoiceFormViewModel
@{
    ViewData["Title"] = "Editar Fatura";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@ViewData["Title"]</h1>
    <a asp-action="Details" asp-route-id="@Model.Invoice.Id" class="btn btn-outline-secondary">Ver detalhes</a>
</div>

<form asp-action="Edit" method="post" class="card shadow-sm">
    <div class="card-body">
        <input type="hidden" asp-for="Invoice.Id" />
        <partial name="_InvoiceForm" />
    </div>
    <div class="card-footer text-end">
        <button type="submit" class="btn btn-primary">Guardar alterações</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
