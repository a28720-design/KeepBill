@model IEnumerable<KeepBill.Models.Invoice>
@{
    ViewData["Title"] = "Faturas";
    var selectedStatus = ViewData["SelectedStatus"] as string;
    var selectedSource = ViewData["SelectedSource"] as string;
    var search = ViewData["Search"] as string;
    var dueFrom = ViewData["DueFrom"] as string;
    var dueTo = ViewData["DueTo"] as string;
    var dueSoonDays = ViewData["DueSoonDays"] as int?;
    var overdueOnly = (bool)(ViewData["OverdueOnly"] ?? false);
    var statuses = ViewData["Statuses"] as string[];
    var invoiceCount = Model.Count();
    var totalAmount = Model.Sum(i => i.GrandTotal);
    var totalBalance = Model.Sum(i => i.GrandTotal - i.Payments.Sum(p => p.Amount));
    var emailLastSyncUtc = ViewData["EmailLastSyncUtc"] as DateTime?;
    var emailLastError = ViewData["EmailLastError"] as string;
    var emailImported = (int)(ViewData["EmailImported"] ?? 0);
    var emailSkipped = (int)(ViewData["EmailSkipped"] ?? 0);
    var emailConfigured = (bool)(ViewData["EmailConfigured"] ?? false);
    var emailHost = ViewData["EmailHost"] as string;
    var emailUsername = ViewData["EmailUsername"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div class="btn-group">
        <a asp-action="Create" class="btn btn-success">+ Nova Fatura</a>
        <a asp-action="ExportCsv"
           asp-route-status="@selectedStatus"
           asp-route-source="@selectedSource"
           asp-route-search="@search"
           asp-route-dueFrom="@dueFrom"
           asp-route-dueTo="@dueTo"
           asp-route-dueSoonDays="@dueSoonDays"
           asp-route-overdueOnly="@overdueOnly"
           class="btn btn-outline-secondary">Exportar CSV</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-3 justify-content-between align-items-center">
        <div>
            <p class="text-muted mb-1">Sincronizacao de faturas por email</p>
            <p class="mb-0">
                Ultima sync:
                <strong>@(emailLastSyncUtc.HasValue ? emailLastSyncUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "ainda nao executada")</strong>
            </p>
            <p class="mb-0 small text-muted">
                Estado:
                @if (emailConfigured)
                {
                    <span class="text-success">configurado para a tua conta</span>
                }
                else
                {
                    <span class="text-danger">por configurar</span>
                }
            </p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-success">Novas: @emailImported</span>
            <span class="badge bg-secondary">Duplicadas: @emailSkipped</span>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(emailLastError))
    {
        <div class="card-footer text-danger small">
            Ultimo erro: @emailLastError
        </div>
    }
</div>

<div class="card mb-3">
    <div class="card-header bg-white">
        <h5 class="mb-0">Configuracao da tua caixa de email</h5>
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">
            Definicoes gerais ja configuradas pelo sistema
            (@(string.IsNullOrWhiteSpace(emailHost) ? "IMAP" : emailHost)).
            Aqui so precisas de indicar o teu email e password da caixa de correio.
        </p>
        <form asp-action="SaveEmailSettings" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-md-6">
                <label class="form-label mb-1">Utilizador</label>
                <input name="username" value="@emailUsername" class="form-control" placeholder="teuemail@dominio.com" />
            </div>
            <div class="col-md-6">
                <label class="form-label mb-1">Password/App Password</label>
                <input type="password" name="password" class="form-control" placeholder="Deixa em branco para manter" />
            </div>
            <div class="col-12 d-flex gap-3 align-items-center">
                <button type="submit" class="btn btn-primary ms-auto">Guardar e sincronizar</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card"><div class="card-body"><p class="text-muted mb-1">Faturas no filtro</p><h4 class="mb-0">@invoiceCount</h4></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><p class="text-muted mb-1">Total faturado</p><h4 class="mb-0">@totalAmount.ToString("C")</h4></div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-body"><p class="text-muted mb-1">Total em falta</p><h4 class="mb-0">@totalBalance.ToString("C")</h4></div></div>
    </div>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-lg-3">
        <label class="form-label mb-1">Pesquisar</label>
        <input type="text" name="search" value="@search" class="form-control" placeholder="N.o fatura ou cliente" />
    </div>
    <div class="col-12 col-lg-2">
        <label class="form-label mb-1">Estado</label>
        <select name="status" class="form-select">
            <option value="">Todos os estados</option>
            @if (statuses != null)
            {
                foreach (var st in statuses)
                {
                    <option value="@st" selected="@(selectedStatus == st ? "selected" : null)">@st</option>
                }
            }
        </select>
    </div>
    <div class="col-12 col-lg-2">
        <label class="form-label mb-1">Origem</label>
        <select name="source" class="form-select">
            <option value="" selected="@(string.IsNullOrWhiteSpace(selectedSource) ? "selected" : null)">Todas</option>
            <option value="manual" selected="@(selectedSource == "manual" ? "selected" : null)">Manual</option>
            <option value="email" selected="@(selectedSource == "email" ? "selected" : null)">Email</option>
        </select>
    </div>
    <div class="col-6 col-lg-2">
        <label class="form-label mb-1">Venc. de</label>
        <input type="date" name="dueFrom" value="@dueFrom" class="form-control" />
    </div>
    <div class="col-6 col-lg-2">
        <label class="form-label mb-1">Venc. ate</label>
        <input type="date" name="dueTo" value="@dueTo" class="form-control" />
    </div>
    <div class="col-6 col-lg-2">
        <label class="form-label mb-1">Vence em (dias)</label>
        <input type="number" min="1" name="dueSoonDays" value="@dueSoonDays" class="form-control" placeholder="Ex: 7" />
    </div>
    <div class="col-12 col-lg-auto">
        <div class="form-check mt-lg-4">
            <input class="form-check-input" type="checkbox" id="overdueOnly" name="overdueOnly" value="true" checked="@overdueOnly" />
            <label class="form-check-label" for="overdueOnly">So vencidas</label>
        </div>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-outline-primary">Filtrar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
    </div>
</form>

<div class="table-responsive shadow-sm bg-white">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Numero</th>
                <th>Origem</th>
                <th>Cliente</th>
                <th>Emissao</th>
                <th>Vencimento</th>
                <th>Estado</th>
                <th>Total</th>
                <th>Saldo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="9" class="text-center text-muted py-4">Ainda nao existem faturas.</td>
            </tr>
        }
        else
        {
            foreach (var invoice in Model)
            {
                var paid = invoice.Payments.Sum(p => p.Amount);
                var balance = invoice.GrandTotal - paid;
                var isImportedFromEmail = invoice.Number.StartsWith("EML-", StringComparison.OrdinalIgnoreCase);
                var isOverdue = invoice.DueDate.Date < DateTime.UtcNow.Date &&
                                invoice.Status != KeepBill.Models.InvoiceStatus.Paid &&
                                invoice.Status != KeepBill.Models.InvoiceStatus.Cancelled;
                <tr>
                    <td>@invoice.Number</td>
                    <td>
                        @if (isImportedFromEmail)
                        {
                            <span class="badge bg-info text-dark">Email</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Manual</span>
                        }
                    </td>
                    <td>@invoice.Customer?.Name</td>
                    <td>@invoice.IssueDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @invoice.DueDate.ToString("dd/MM/yyyy")
                        @if (isOverdue)
                        {
                            <span class="badge bg-danger ms-1">Vencida</span>
                        }
                    </td>
                    <td>
                        <span class="badge @GetStatusClass(invoice.Status)">@invoice.Status</span>
                    </td>
                    <td>@invoice.GrandTotal.ToString("C")</td>
                    <td>@balance.ToString("C")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@invoice.Id" class="btn btn-sm btn-primary">Editar</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@functions{
    private string GetStatusClass(KeepBill.Models.InvoiceStatus status)
    {
        return status switch
        {
            KeepBill.Models.InvoiceStatus.Paid => "bg-success",
            KeepBill.Models.InvoiceStatus.PartiallyPaid => "bg-info",
            KeepBill.Models.InvoiceStatus.Cancelled => "bg-secondary",
            KeepBill.Models.InvoiceStatus.Issued => "bg-primary",
            _ => "bg-warning text-dark"
        };
    }
}
