<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KeepBill</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-body d-flex align-items-center py-4">
    <div class="container auth-container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-xl-5">
                <div class="card shadow-lg border-0 auth-card">
                    <div class="card-body p-4 p-md-5">
                        <div class="auth-branding mb-4">
                            <span class="auth-badge">Plataforma de faturacao</span>
                            <h1 class="h3 fw-bold mb-1">KeepBill</h1>
                            <p class="auth-subtitle mb-0">Gestao de faturacao para o teu negocio.</p>
                        </div>
                        @RenderBody()
                    </div>
                </div>
                <p class="text-center text-white-50 mt-3 small">&copy; @DateTime.UtcNow.Year KeepBill</p>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_Toast" />
    @RenderSection("Scripts", required: false)
</body>
</html>
