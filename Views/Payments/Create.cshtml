@model KeepBill.Models.Payment
@{
    var invoice = ViewData["Invoice"] as KeepBill.Models.Invoice;
    ViewData["Title"] = $"Registar pagamento - {invoice?.Number}";
    var methods = ViewBag.Methods as SelectList;
    var remainingAmount = ViewData["RemainingAmount"] is decimal remaining ? remaining : 0m;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4">@ViewData["Title"]</h1>
    <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice?.Id" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Cliente</dt>
            <dd class="col-sm-9">@invoice?.Customer?.Name</dd>
            <dt class="col-sm-3">Total</dt>
            <dd class="col-sm-9">@invoice?.GrandTotal.ToString("C")</dd>
            <dt class="col-sm-3">Em falta</dt>
            <dd class="col-sm-9">@remainingAmount.ToString("C")</dd>
        </dl>
    </div>
</div>

<form asp-action="Create" method="post" class="card shadow-sm mt-3">
    <div class="card-body row g-3">
        <input type="hidden" asp-for="InvoiceId" />
        <div class="col-md-4">
            <label asp-for="Amount" class="form-label">Valor recebido</label>
            <input asp-for="Amount" class="form-control" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Method" class="form-label">Método</label>
            <select asp-for="Method" class="form-select" asp-items="methods"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="PaidAt" class="form-label">Data</label>
            <input asp-for="PaidAt" class="form-control" type="date" />
        </div>
        <div class="col-md-6">
            <label asp-for="Reference" class="form-label">Referência</label>
            <input asp-for="Reference" class="form-control" />
            <span asp-validation-for="Reference" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label">Notas</label>
            <textarea asp-for="Notes" rows="2" class="form-control"></textarea>
        </div>
    </div>
    <div class="card-footer text-end">
        <button type="submit" class="btn btn-primary">Registar pagamento</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
