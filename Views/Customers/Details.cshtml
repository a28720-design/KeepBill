@model KeepBill.Models.Customer
@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@ViewData["Title"]</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">NIF</dt>
            <dd class="col-sm-9">@Model.TaxId</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Morada</dt>
            <dd class="col-sm-9">@Model.BillingAddress</dd>

            <dt class="col-sm-3">Cidade</dt>
            <dd class="col-sm-9">@Model.City</dd>

            <dt class="col-sm-3">País</dt>
            <dd class="col-sm-9">@Model.Country</dd>

            <dt class="col-sm-3">Notas</dt>
            <dd class="col-sm-9">@Model.Notes</dd>

            <dt class="col-sm-3">Criado em</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime()</dd>

            <dt class="col-sm-3">Atualizado em</dt>
            <dd class="col-sm-9">@Model.UpdatedAt?.ToLocalTime()</dd>
        </dl>
    </div>
</div>
