@model KeepBill.Models.ViewModels.CustomerDetailsViewModel
@{
    ViewData["Title"] = "Detalhes do Cliente";
    var customer = Model.Customer;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h3 mb-0">@ViewData["Title"]</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-primary me-2">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Total faturas</p>
                <h3 class="mb-0">@Model.TotalInvoices</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Faturado</p>
                <h3 class="mb-0">@Model.TotalInvoiced.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Recebido</p>
                <h3 class="mb-0">@Model.TotalPaid.ToString("C")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-danger-subtle">
            <div class="card-body">
                <p class="text-muted mb-1">Em divida</p>
                <h3 class="mb-0 text-danger">@Model.OutstandingBalance.ToString("C")</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@customer.Name</dd>

            <dt class="col-sm-3">NIF</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.TaxId) ? "-" : customer.TaxId)</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.Email) ? "-" : customer.Email)</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.Phone) ? "-" : customer.Phone)</dd>

            <dt class="col-sm-3">Morada</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.BillingAddress) ? "-" : customer.BillingAddress)</dd>

            <dt class="col-sm-3">Cidade</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.City) ? "-" : customer.City)</dd>

            <dt class="col-sm-3">Pais</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.Country) ? "-" : customer.Country)</dd>

            <dt class="col-sm-3">Notas</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(customer.Notes) ? "-" : customer.Notes)</dd>
        </dl>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="mb-0">Ultimas faturas</h5>
    <a asp-controller="Invoices" asp-action="Create" class="btn btn-sm btn-outline-primary">Nova fatura</a>
</div>

<div class="table-responsive bg-white shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Numero</th>
                <th>Emissao</th>
                <th>Vencimento</th>
                <th>Estado</th>
                <th>Total</th>
                <th>Saldo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.RecentInvoices.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Sem faturas para este cliente.</td>
            </tr>
        }
        else
        {
            foreach (var invoice in Model.RecentInvoices)
            {
                <tr>
                    <td>@invoice.Number</td>
                    <td>@invoice.IssueDate.ToString("dd/MM/yyyy")</td>
                    <td>@invoice.DueDate.ToString("dd/MM/yyyy")</td>
                    <td>@invoice.Status</td>
                    <td>@invoice.Total.ToString("C")</td>
                    <td>@invoice.Balance.ToString("C")</td>
                    <td class="text-end">
                        <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
