@model KeepBill.Models.Customer
@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">@ViewData["Title"]</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar à lista</a>
</div>

<form asp-action="Create" method="post" class="card shadow-sm">
    <div class="card-body">
        <partial name="_CustomerForm" />
    </div>
    <div class="card-footer text-end">
        <button type="submit" class="btn btn-primary">Guardar cliente</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
